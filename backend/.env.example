# Backend Environment Variables
# Copy this file to .env and fill in your values

# Database
DATABASE_URL="postgresql://startoil_user:password123@localhost:5432/startoil"
DB_HOST=localhost
DB_PORT=5432
DB_NAME=startoil
DB_USER=startoil_user
DB_PASSWORD=password123

# Server
NODE_ENV=development
PORT=3000
API_URL=http://localhost:3000

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-long-abc123xyz
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-32-chars-long-def456uvw
JWT_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=7d

# Email (Nodemailer)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=noreply@gasstation.local
MAIL_PASSWORD=your-app-password
MAIL_FROM=StarOil <noreply@gasstation.local>

# Logging
LOG_LEVEL=debug
LOG_FILE=logs/combined.log
LOG_ERROR_FILE=logs/error.log

# CORS
CORS_ORIGINS=http://localhost:3001,http://localhost:5173,https://manager.gasstation.local

# Features
ENABLE_OFFLINE_SYNC=true
SYNC_RETRY_INTERVAL=30000
SYNC_MAX_RETRIES=5

# Backup
BACKUP_ENABLED=true
BACKUP_PATH=./backups
BACKUP_SCHEDULE=0 2 * * *

# Audit Logging
ENABLE_AUDIT_LOG=true
AUDIT_LOG_RETENTION_DAYS=365

# Security
BCRYPT_ROUNDS=12
SESSION_TIMEOUT=1800000
HTTPS_ENABLED=false
