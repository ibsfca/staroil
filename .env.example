# Root Environment Variables
# This file applies to all services (Docker Compose)

# General
ENVIRONMENT=development
DOMAIN=manager.gasstation.local

# Database
DB_NAME=startoil
DB_USER=startoil_user
DB_PASSWORD=change_me_in_production_12345
DB_HOST=postgres
DB_PORT=5432

# JWT Secrets
JWT_SECRET=your_jwt_secret_key_min_32_characters_long_change_this_please_xyz
JWT_REFRESH_SECRET=your_refresh_secret_key_min_32_characters_long_change_this_xyz

# Email Configuration
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=noreply@gasstation.local
MAIL_PASSWORD=your_app_password_here
MAIL_FROM=StarOil <noreply@gasstation.local>

# Node Environment
NODE_ENV=production
LOG_LEVEL=info

# API
API_URL=https://manager.gasstation.local/api
CORS_ORIGINS=https://manager.gasstation.local

# Features
ENABLE_OFFLINE_SYNC=true
ENABLE_AUDIT_LOG=true

# Security
HTTPS_ENABLED=true
BCRYPT_ROUNDS=12

# Backup
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
